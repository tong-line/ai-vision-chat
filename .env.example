# 对话模式：mock（无 Key 演示）| direct（浏览器直连大模型）| proxy（走后端代理）
VITE_CHAT_MODE=direct

# 智谱 AI 配置（direct 模式）
# 申请地址：https://open.bigmodel.cn
VITE_LLM_API_KEY=你的智谱API_Key
VITE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VITE_LLM_MODEL=glm-4.6v

# 后端代理地址（proxy 模式使用，后续自行补充后端）
VITE_API_BASE_URL=http://localhost:3001

# 语音合成：edge（微软神经网络，推荐）| browser（浏览器内置）
VITE_TTS_PROVIDER=edge
VITE_TTS_VOICE=zh-CN-XiaoxiaoNeural
